{
  "name": "fhebc-besu-fhe",
  "version": "0.1.0",
  "private": true,
  "description": "BesuFHE: modified Besu with native TFHE-rs execution, on-chain ciphertexts, and lightweight input proofs.",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "build:native": "node scripts/local-besu-network.js build-native",
    "build:besu": "node scripts/local-besu-network.js build",
    "configure:besu": "node scripts/local-besu-network.js configure",
    "start:besu": "node scripts/local-besu-network.js start",
    "stop:besu": "node scripts/local-besu-network.js stop",
    "reset:besu": "node scripts/local-besu-network.js reset",
    "status:besu": "node scripts/local-besu-network.js status",
    "deploy:besu": "hardhat run scripts/deploy/deploy-light-input-stack.ts --network fhebcBesu",
    "proof:build:energy-input": "node scripts/proof/groth16/build.js energy-input",
    "proof:prove:energy-input": "node scripts/proof/groth16/prove-energy-input.js",
    "proof:build:operation-authority": "node scripts/proof/groth16/build.js operation-authority",
    "proof:prove:operation-authority": "node scripts/proof/groth16/prove-operation-authority.js",
    "proof:build:energy-input:groth16": "node scripts/proof/groth16/build.js energy-input",
    "proof:prove:energy-input:groth16": "node scripts/proof/groth16/prove-energy-input.js",
    "proof:build:operation-authority:groth16": "node scripts/proof/groth16/build.js operation-authority",
    "proof:prove:operation-authority:groth16": "node scripts/proof/groth16/prove-operation-authority.js",
    "interact:besu": "hardhat run scripts/interact/energy-notary-benchmark.ts --network fhebcBesu",
    "benchmark:besu": "hardhat run scripts/interact/energy-notary-benchmark-10x.ts --network fhebcBesu",
    "benchmark:besu:proof-backed-onchain": "node scripts/benchmark/run-proof-backed-onchain-groth16.js",
    "benchmark:besu:load": "hardhat run scripts/benchmark/load-besufhe-notarize.ts --network fhebcBesu",
    "smoke:besu:precompile": "node scripts/local-besu-network.js smoke-precompile"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.0.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.0.0",
    "hardhat": "^2.22.0",
    "snarkjs": "^0.7.6",
    "typescript": "^5.0.0"
  }
}
